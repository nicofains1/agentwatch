{
  "name": "@nicofains1/agentwatch",
  "version": "0.2.1",
  "description": "Multi-agent observability: cascade failure detection, heartbeats, and forensic replay",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentwatch": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": { "optional": true },
    "@opentelemetry/sdk-trace-base": { "optional": true }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@types/better-sqlite3": "^7.6.8"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "agents",
    "observability",
    "cascade-failure",
    "multi-agent",
    "monitoring",
    "heartbeat",
    "tracing",
    "fleet-management",
    "ai-agents",
    "debugging",
    "opentelemetry",
    "otel"
  ],
  "author": "nicofains1",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicofains1/agentwatch.git"
  },
  "homepage": "https://github.com/nicofains1/agentwatch",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
